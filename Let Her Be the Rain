<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Three Weeks Between - Let Her Be the Rain | A Novel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --gold: #D4AF37;
            --gold-light: #F4E8C1;
            --copper: #B87333;
            --copper-light: #E6C9A8;
            --emerald: #2C5F2D;
            --emerald-dark: #1A3A1B;
            --black: #0D0D0D;
            --charcoal: #1C1C1C;
            --cream: #FAF7F2;
            --warm-white: #F5F0E8;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--black);
            color: var(--cream);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1.5rem 3rem;
            background: linear-gradient(to bottom, rgba(13,13,13,0.95), transparent);
            z-index: 1000;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            color: var(--gold);
            letter-spacing: 2px;
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--cream);
            text-decoration: none;
            font-size: 0.85rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            transition: color 0.3s ease;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--gold);
            transition: width 0.3s ease;
        }

        .nav-links a:hover {
            color: var(--gold);
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: 
                radial-gradient(ellipse at top right, rgba(184,115,51,0.15) 0%, transparent 50%),
                radial-gradient(ellipse at bottom left, rgba(44,95,45,0.2) 0%, transparent 50%),
                linear-gradient(to bottom, var(--charcoal), var(--black));
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(212,175,55,0.08) 0%, transparent 70%);
            border-radius: 50%;
            animation: pulse 8s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }

        .hero-content {
            text-align: center;
            z-index: 2;
            max-width: 900px;
            padding: 2rem;
        }

        .hero-subtitle {
            font-family: 'Cormorant Garamond', serif;
            font-style: italic;
            font-size: 1.3rem;
            color: var(--copper-light);
            margin-bottom: 1rem;
            letter-spacing: 3px;
        }

        .hero h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 300;
            color: var(--gold-light);
            line-height: 1.1;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
        }

        .hero h1 span {
            display: block;
            font-size: 0.5em;
            color: var(--copper);
            margin-top: 0.5rem;
            letter-spacing: 4px;
            text-transform: uppercase;
        }

        .hero-tagline {
            font-size: 1.1rem;
            color: var(--cream);
            opacity: 0.8;
            max-width: 600px;
            margin: 0 auto 3rem;
            font-weight: 300;
        }

        .golden-key {
            width: 80px;
            height: 80px;
            margin: 2rem auto;
            position: relative;
        }

        .golden-key svg {
            width: 100%;
            height: 100%;
            fill: none;
            stroke: var(--gold);
            stroke-width: 1.5;
            filter: drop-shadow(0 0 20px rgba(212,175,55,0.3));
        }

        .cta-button {
            display: inline-block;
            padding: 1rem 3rem;
            border: 1px solid var(--gold);
            color: var(--gold);
            text-decoration: none;
            font-size: 0.9rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            background: transparent;
            cursor: pointer;
        }

        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(212,175,55,0.2), transparent);
            transition: left 0.5s ease;
        }

        .cta-button:hover::before {
            left: 100%;
        }

        .cta-button:hover {
            background: rgba(212,175,55,0.1);
            box-shadow: 0 0 30px rgba(212,175,55,0.2);
        }

        /* Jasmine Decoration */
        .jasmine-decoration {
            position: absolute;
            opacity: 0.1;
            pointer-events: none;
        }

        .jasmine-1 {
            top: 10%;
            left: 5%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, var(--gold) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(40px);
        }

        .jasmine-2 {
            bottom: 20%;
            right: 10%;
            width: 150px;
            height: 150px;
            background: radial-gradient(circle, var(--emerald) 0%, transparent 70%);
            border-radius: 50%;
            filter: blur(30px);
        }

        /* Section Styling */
        section {
            padding: 6rem 2rem;
            position: relative;
        }

        .section-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
            color: var(--gold);
            text-align: center;
            margin-bottom: 3rem;
            position: relative;
            display: inline-block;
            left: 50%;
            transform: translateX(-50%);
        }

        .section-title::after {
            content: '❦';
            display: block;
            text-align: center;
            color: var(--copper);
            font-size: 1rem;
            margin-top: 0.5rem;
        }

        /* The Story Section */
        .story-section {
            background: linear-gradient(to bottom, var(--black), var(--charcoal));
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
        }

        .book-visual {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .book-cover {
            width: 350px;
            height: 500px;
            background: linear-gradient(135deg, var(--charcoal) 0%, var(--black) 100%);
            border: 2px solid var(--gold);
            box-shadow: 
                0 20px 60px rgba(0,0,0,0.5),
                0 0 0 1px var(--copper),
                inset 0 0 60px rgba(212,175,55,0.05);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            text-align: center;
        }

        .book-cover::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 20px;
            right: 20px;
            bottom: 20px;
            border: 1px solid rgba(212,175,55,0.3);
            pointer-events: none;
        }

        .book-cover h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            color: var(--gold-light);
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }

        .book-cover .author {
            color: var(--copper-light);
            font-size: 0.9rem;
            letter-spacing: 2px;
        }

        .book-spine {
            position: absolute;
            left: -30px;
            width: 30px;
            height: 100%;
            background: linear-gradient(to right, var(--copper), var(--gold));
            transform: perspective(100px) rotateY(-30deg);
            box-shadow: -5px 0 20px rgba(0,0,0,0.3);
        }

        .story-text {
            padding: 2rem;
        }

        .story-text p {
            font-size: 1.1rem;
            line-height: 1.8;
            color: var(--cream);
            opacity: 0.9;
            margin-bottom: 1.5rem;
        }

        .story-text .quote {
            font-family: 'Cormorant Garamond', serif;
            font-style: italic;
            font-size: 1.3rem;
            color: var(--gold);
            border-left: 2px solid var(--copper);
            padding-left: 1.5rem;
            margin: 2rem 0;
        }

        /* Characters Section */
        .characters-section {
            background: var(--charcoal);
            position: relative;
        }

        .characters-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .character-card {
            background: linear-gradient(135deg, rgba(28,28,28,0.8), rgba(13,13,13,0.9));
            border: 1px solid rgba(212,175,55,0.2);
            padding: 2.5rem;
            text-align: center;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .character-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(to right, transparent, var(--gold), transparent);
            transform: scaleX(0);
            transition: transform 0.4s ease;
        }

        .character-card:hover::before {
            transform: scaleX(1);
        }

        .character-card:hover {
            transform: translateY(-5px);
            border-color: rgba(212,175,55,0.4);
            box-shadow: 0 10px 40px rgba(212,175,55,0.1);
        }

        .character-icon {
            width: 60px;
            height: 60px;
            margin: 0 auto 1.5rem;
            border: 1px solid var(--copper);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--gold);
        }

        .character-card h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            color: var(--gold-light);
            margin-bottom: 0.5rem;
        }

        .character-card .role {
            color: var(--copper);
            font-size: 0.8rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .character-card p {
            font-size: 0.95rem;
            color: var(--cream);
            opacity: 0.8;
            line-height: 1.6;
        }

        /* Aesthetic Gallery */
        .aesthetic-section {
            background: var(--black);
            padding: 6rem 2rem;
        }

        .mood-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 1000px;
            margin: 0 auto;
        }

        .mood-item {
            aspect-ratio: 1;
            background: var(--charcoal);
            border: 1px solid rgba(212,175,55,0.15);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }

        .mood-item::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center, transparent 0%, rgba(0,0,0,0.4) 100%);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .mood-item:hover::after {
            opacity: 1;
        }

        .mood-item:hover {
            border-color: var(--gold);
            transform: scale(1.02);
        }

        .mood-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            filter: grayscale(100%) brightness(0.8) sepia(100%) hue-rotate(10deg) saturate(200%);
            transition: all 0.4s ease;
        }

        .mood-item:hover .mood-icon {
            filter: none;
            transform: scale(1.1);
        }

        .mood-item h4 {
            font-family: 'Cormorant Garamond', serif;
            color: var(--copper-light);
            font-size: 1rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            z-index: 1;
        }

        /* Newsletter Section */
        .newsletter-section {
            background: linear-gradient(to bottom, var(--charcoal), var(--emerald-dark));
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .newsletter-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(to right, transparent, var(--gold), transparent);
        }

        .newsletter-content {
            max-width: 600px;
            margin: 0 auto;
            position: relative;
            z-index: 2;
        }

        .newsletter-section p {
            color: var(--cream);
            opacity: 0.8;
            margin-bottom: 2rem;
            font-size: 1.1rem;
        }

        .newsletter-form {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .newsletter-form input {
            padding: 1rem 1.5rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--copper);
            color: var(--cream);
            font-family: 'Montserrat', sans-serif;
            font-size: 0.9rem;
            min-width: 300px;
            outline: none;
            transition: all 0.3s ease;
        }

        .newsletter-form input:focus {
            border-color: var(--gold);
            background: rgba(255,255,255,0.08);
        }

        .newsletter-form input::placeholder {
            color: var(--copper-light);
            opacity: 0.6;
        }

        .newsletter-form button {
            padding: 1rem 2.5rem;
            background: var(--gold);
            color: var(--black);
            border: none;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.9rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .newsletter-form button:hover {
            background: var(--copper-light);
            box-shadow: 0 5px 20px rgba(212,175,55,0.3);
        }

        /* Footer */
        footer {
            background: var(--black);
            padding: 3rem 2rem;
            text-align: center;
            border-top: 1px solid rgba(212,175,55,0.1);
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .social-links a {
            color: var(--copper);
            text-decoration: none;
            font-size: 0.9rem;
            letter-spacing: 1px;
            transition: color 0.3s ease;
        }

        .social-links a:hover {
            color: var(--gold);
        }

        .copyright {
            color: var(--copper);
            opacity: 0.6;
            font-size: 0.85rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            nav {
                padding: 1rem;
            }
            .nav-links {
                gap: 1rem;
            }
            .nav-links a {
                font-size: 0.75rem;
            }
            .story-section {
                grid-template-columns: 1fr;
            }
            .book-cover {
                width: 280px;
                height: 400px;
            }
            .mood-grid {
                grid-template-columns: 1fr;
            }
            .characters-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Smooth Scroll */
        html {
            scroll-behavior: smooth;
        }

        /* Fade In Animation */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <a href="#" class="logo">Three Weeks Between</a>
        <ul class="nav-links">
            <li><a href="#story">The Story</a></li>
            <li><a href="#characters">Characters</a></li>
            <li><a href="#world">World</a></li>
            <li><a href="#newsletter">Updates</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="jasmine-decoration jasmine-1"></div>
        <div class="jasmine-decoration jasmine-2"></div>
        
        <div class="hero-content">
            <p class="hero-subtitle">A Novel</p>
            <h1>
                Three Weeks Between
                <span>Let Her Be the Rain</span>
            </h1>
            <div class="golden-key">
                <svg viewBox="0 0 100 100">
                    <path d="M30,50 L50,50 L50,35 L60,35 L60,45 L70,45 L70,35 L80,35 L80,65 L70,65 L70,55 L60,55 L60,65 L50,65 L50,50 L30,50 C25,50 20,45 20,40 C20,30 30,25 40,25 C50,25 55,30 55,40" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="35" cy="40" r="3" fill="var(--gold)"/>
                </svg>
            </div>
            <p class="hero-tagline">
                A story of healing, sisterhood, and the courage to love again. 
                When the key is returned, everything changes.
            </p>
            <a href="#story" class="cta-button">Discover the Story</a>
        </div>
    </section>

    <!-- The Story Section -->
    <section id="story" class="story-section fade-in">
        <div class="book-visual">
            <div class="book-cover">
                <div class="book-spine"></div>
                <h3>Three Weeks Between</h3>
                <p class="author">Let Her Be the Rain</p>
                <div style="margin-top: 2rem; font-size: 3rem; opacity: 0.5;">🌸</div>
            </div>
        </div>
        
        <div class="story-text">
            <h2 class="section-title">The Story</h2>
            <p>
                <strong>Adeline</strong> is thirty-two, recovering from cancer treatment, and learning how to breathe again. 
                She didn't expect to fall in love. She certainly didn't expect <strong>Salman</strong>—a record label owner 
                with a past as complicated as her own.
            </p>
            <p>
                Between them stands <strong>Noura</strong>, Salman's childhood friend, whose obsession threatens to unravel 
                everything. But Adeline has her sister <strong>Blake</strong>, her fierce protector, and a strength she 
                never knew she possessed.
            </p>
            <div class="quote">
                "He returned the key. She kept the necklace. And in the space between, they found something worth fighting for."
            </div>
            <p>
                A romance about second chances, the bonds of sisterhood, and discovering that even after the darkest storms, 
                we can learn to be the rain—gentle, persistent, and life-giving.
            </p>
        </div>
    </section>

    <!-- Characters Section -->
    <section id="characters" class="characters-section fade-in">
        <h2 class="section-title">The Characters</h2>
        
        <div class="characters-grid">
            <div class="character-card">
                <div class="character-icon">🌸</div>
                <h3>Adeline</h3>
                <p class="role">The Survivor</p>
                <p>Thirty-two. Healing. Learning to trust her body and her heart again. Wears a golden jasmine necklace that means more than words.</p>
            </div>
            
            <div class="character-card">
                <div class="character-icon">🗝️</div>
                <h3>Salman</h3>
                <p class="role">The Record Label Owner</p>
                <p>Successful, guarded, carrying keys to doors he never thought he'd open again. Until he met her.</p>
            </div>
            
            <div class="character-card">
                <div class="character-icon">🛡️</div>
                <h3>Blake</h3>
                <p class="role">The Sister</p>
                <p>Fierce, loyal, and ready to burn the world down for Adeline. The anchor in every storm.</p>
            </div>
            
            <div class="character-card">
                <div class="character-icon">🐱</div>
                <h3>Noura</h3>
                <p class="role">The Shadow</p>
                <p>Childhood friend turned obsession. She'll question everything—even the paternity of a pregnancy—to keep Salman close.</p>
            </div>
        </div>
    </section>

    <!-- Aesthetic World Section -->
    <section id="world" class="aesthetic-section fade-in">
        <h2 class="section-title">The World</h2>
        
        <div class="mood-grid">
            <div class="mood-item">
                <div class="mood-icon">🌸</div>
                <h4>Golden Jasmine</h4>
            </div>
            <div class="mood-item">
                <div class="mood-icon">🗝️</div>
                <h4>The Returned Key</h4>
            </div>
            <div class="mood-item">
                <div class="mood-icon">🐱</div>
                <h4>Tabby Cat</h4>
            </div>
            <div class="mood-item">
                <div class="mood-icon">🥉</div>
                <h4>Warm Copper</h4>
            </div>
            <div class="mood-item">
                <div class="mood-icon">💚</div>
                <h4>Deep Emerald</h4>
            </div>
            <div class="mood-item">
                <div class="mood-icon">✨</div>
                <h4>Calm Glamour</h4>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <section id="newsletter" class="newsletter-section fade-in">
        <div class="newsletter-content">
            <h2 class="section-title">Stay Updated</h2>
            <p>
                Be the first to know when "Three Weeks Between - Let Her Be the Rain" is available. 
                Join for exclusive updates, early chapters, and behind-the-scenes glimpses into Adeline and Salman's world.
            </p>
            
            <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Thank you for subscribing! You\'ll receive updates about the book soon.');">
                <input type="email" placeholder="Your email address" required>
                <button type="submit">Subscribe</button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="social-links">
            <a href="#">Instagram</a>
            <a href="#">Twitter</a>
            <a href="#">Goodreads</a>
            <a href="#">Contact</a>
        </div>
        <p class="copyright">© 2026 Three Weeks Between. All rights reserved.</p>
    </footer>

    <script>
        // Fade in animation on scroll
        const observerOptions = {
            threshold: 0.1,
            rootMargin: "0px 0px -50px 0px"
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

        // Smooth scroll for navigation
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Parallax effect for hero decorations
        window.addEventListener('scroll', () => {
            const scrolled = window.pageYOffset;
            const parallax = document.querySelectorAll('.jasmine-decoration');
            parallax.forEach((el, index) => {
                const speed = 0.5 + (index * 0.2);
                el.style.transform = `translateY(${scrolled * speed}px)`;
            });
        });
    </script>
</body>
</html>
